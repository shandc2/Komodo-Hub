{% from "button.jinja" import button %}
<div class="navbar">
    <a href="/" style="height:100%">
        <img src="/images/lizard.png" height="100%">
    </a>
    <div class="links">
        {% if user %}
        {% if user[4] %}
        <a href="/admin">Admin</a>
        {% endif %}
        <a href="/dashboard">Dashboard</a>
        <a href="/logout">Logout</a>
        {% else %}
        {{ button(url='/login', button_text='Login/Register', extra_classes='') }}
        {% endif %}
    </div>
</div>