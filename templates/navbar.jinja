{% from "button.jinja" import button %}
<div class="navbar">
    <div class="left">
        <a href="/" class="left">
            <img src="/images/lizard.png" class="logo-img">
            <span class="logo-text">Komodo Hub</span>
        </a>
    </div>

    <div class="links">
        {% if user %}
        {% if user["account_type"] == "admin" %}
        <div class="dropdown">
            <a class="dropbtn">Devtools ▾</a>
            <div class="dropdown-content">
                <a href="/about">About</a>
                <a href="/species/portal">Add Species</a>
                <a href="/species">View Species</a>
                <a href="/species_search">Search Species</a>
                <a href="/login">Login</a>
                <a href="/register">Register new user</a>
                <a href="/dashboard">Dashboard</a>
            </div>
        </div>
        <a href="/admin">Admin</a>
        {% endif %}
        <div class="dropdown">
            <a class="dropbtn">{{user["username"]}} ▾</a>
            <div class="dropdown-content">
                <a href="/dashboard">Dashboard</a>
                <a href="/settings">Settings</a>
                <a href="/logout">Logout</a>
            </div>
        </div>
        <a href="/about">About</a>
        {% else %}
        {{ button(url='/login', button_text='Login', extra_classes='') }}
        {{ button(url='/register', button_text='Register', extra_classes='') }}
        {% endif %}
    </div>
</div>