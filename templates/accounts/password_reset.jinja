{% extends "base.jinja" %}
{% block title %} Set New Password {% endblock %}
{% block head %}
{% endblock %}
{% block content %}
{% from 'button.jinja' import button %}
<section id="hero" class="form">
    <div class="container">
        {% if error %}
        <p class="form-error">{{ error }}</p>
        {% endif %}
        {% if success %}
        <p class="form-success">{{ success }}</p>
        <p><a href="{{ url_for('login.login') }}">Return to login</a></p>
        {% elif reset_request %}
        <form action="{{ url_for('login.password_reset', token=token) }}" method="POST">
            <div class="form-group">
                <label for="password">New Password:</label>
                <input type="password" id="password" name="password" required>
            </div>
            <div class="form-group">
                <label for="password_confirm">Confirm Password:</label>
                <input type="password" id="password_confirm" name="password_confirm" required>
            </div>
            <button type="submit" class="submit-button">
                Reset Password
            </button>
        </form>
        {% else %}
        <p>Please request a new password reset link.</p>
        <p><a href="{{ url_for('login.password_reset_request') }}">Request another reset link</a></p>
        {% endif %}
    </div>
</section>
{% endblock %}
