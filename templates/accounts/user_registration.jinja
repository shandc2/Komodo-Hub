{# needs to redirect if user logged in #}
{% extends "base.jinja" %}
{% block title %} Register {% endblock %}
{% block head %}
{% endblock %}
{% block content %}
{% from 'button.jinja' import button %}
<section id="hero" class="form">
    <form action="{{ url_for('login.register') }}" class="container" method="POST">
        {% if error %}
        <p class="form-error">{{ error }}</p>
        {% endif %}
        <div class="form-group">
            <label for="username">Username:</label>
            <input type="text" id="username" name="username" required>
        </div>
        <div class="form-group">
            <label for="email">Email:</label>
            <input type="text" id="email" name="email" required>
        </div>
        <div class="form-group">
            <label for="account_type">Account type:</label>
            <select id="account_type" name="account_type" required>
            <option value="private_user">Private User</option>
            <option value="teacher">Teacher</option>
            <option value="student">Student</option>
            <option value="community_leader">Community Leader</option>
        </select> </div>
        <div class="form-group">
            <label for="password">Password:</label>
            <input type="password" id="password" name="password">
        </div>
        <div class="form-group">
            <label for="password_confirm">Confirm Password:</label>
            <input type="password" id="password_confirm" name="password_confirm">
        </div>
        <button type="submit" class="submit-button">
            Register
        </button>
    </form>
</section>
{% endblock %}