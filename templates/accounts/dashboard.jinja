{% extends "base.jinja" %}
{% block title %}Dashboard{% endblock %}
{% block head %}{% endblock %}
{% block content %}
{% from 'button.jinja' import button %}

<section id="hero" style="padding: 40px 20px; text-align: center;">
    <h1>Welcome back, {{ user.username }}.</h1>
    <p style="max-width: 700px; margin: 0.5rem auto;">Your conservation dashboard.</p>
</section>

<section style="padding: 0 20px 40px 20px; max-width: 900px; margin: 0 auto;">

    {#Enrolled Programmes (everyone sees this)#}
    <div class="container-full" style="margin-bottom: 20px;">
        <h2>Your Programmes</h2>
        {% if enrolled_programmes %}
            <div class="species-grid">
                {% for prog in enrolled_programmes %}
                <div class="container-lite">
                    <h3>{{ prog.name }}</h3>
                    <p>{{ prog.description }}</p>
                    {{ button(url='/programmes/' ~ prog.id, button_text='View', extra_classes='homepage-btn') }}
                </div>
                {% endfor %}
            </div>
        {% else %}
            <p style="color: var(--text); opacity: 0.6;">You are not enrolled in any programmes yet.</p>
            {{ button(url='/programmes', button_text='Browse Programmes', extra_classes='homepage-btn') }}
        {% endif %}
    </div>

    {#Student#}
    {% if session.account_type == "student" %}
    <div class="container-full" style="margin-bottom: 20px;">
        <h2>Classes</h2>
        <p>View the classes you have joined.</p>
        {{ button(url='/classes', button_text='View Classes', extra_classes='homepage-btn') }}
    </div>
    {% endif %}

    {#Teacher#}
    {% if user.account_type == "teacher" %}
    <div class="container-full" style="margin-bottom: 20px;">
        <h2>Classes</h2>
        <p>View your classes or set up a new one for your students.</p>
        <div class="homepage-buttons" style="justify-content: flex-start; margin-top: 1rem;">
            {{ button(url='/classes', button_text='View Classes', extra_classes='homepage-btn') }}
        </div>
    </div>
    {% endif %}

    {#Community Leader#}
    {% if user.account_type == "community_leader" %}
    <div class="container-full" style="margin-bottom: 20px;">
        <h2>Programmes</h2>
        <p>Create a new conservation programme for others to join.</p>
        {{ button(url='/programmes/create', button_text='Create a Programme', extra_classes='homepage-btn') }}
    </div>
    {% endif %}

</section>

<section style="padding: 20px; text-align: center;">
    {{ button(url='/logout', button_text='Log Out', extra_classes='homepage-btn') }}
</section>

{% endblock %}