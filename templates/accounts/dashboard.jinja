{% extends "base.jinja" %}
{% block title %}Dashboard{% endblock %}
{% block head %}{% endblock %}
{% block content %}
{% from 'button.jinja' import button %}

<section id="hero" style="padding: 40px 20px; text-align: center;">
    <h1>Welcome back, {{ user.username }}.</h1>
    <p style="max-width: 700px; margin: 0.5rem auto;">Your conservation dashboard.</p>
</section>

<section style="padding: 0 20px 40px 20px; max-width: 900px; margin: 0 auto;">

    {#Enrolled Programs (everyone except community leaders sees this)#}
    {% if user.account_type != "community_leader" %}
    <div class="container-full" style="margin-bottom: 20px">
        <h2>Programs</h2>
        <p>Browse and join programs here</p>
        <div class="homepage-buttons" style="justify-content: flex-start; margin-top: 1rem;">
            {{ button(url='/programs', button_text='Browse Programs', extra_classes='homepage-btn') }}
            {{ button(url='/programs/my', button_text='Joined Programs', extra_classes='homepage-btn') }}
        </div>
    </div>
    {% endif %}

    {#Student#}
    {% if user.account_type == "student" %}
    <div class="container-full" style="margin-bottom: 20px;">
        <h2>Classes</h2>
        <p>View the classes you have joined.</p>
        <div class="homepage-buttons" style="justify-content: flex-start; margin-top: 1rem;">
            {{ button(url='/classes', button_text='View Classes', extra_classes='homepage-btn') }}
        </div>
    </div>
    {% endif %}

    {#Teacher#}
    {% if user.account_type == "teacher" %}
    <div class="container-full" style="margin-bottom: 20px;">
        <h2>Classes</h2>
        <p>View your classes or set up a new one for your students.</p>
        <div class="homepage-buttons" style="justify-content: flex-start; margin-top: 1rem;">
            {{ button(url='/classes', button_text='View Classes', extra_classes='homepage-btn') }}
        </div>
    </div>
    {% endif %}

    {#Community Leader#}
    {% if user.account_type == "community_leader" %}
    <div class="container-full" style="margin-bottom: 20px;">
        <h2>Programs</h2>
        <p>Manage your conservation programs or create a new one.</p>
        <div class="homepage-buttons" style="justify-content: flex-start; margin-top: 1rem;">
            {{ button(url='/programs/my', button_text='My Programs', extra_classes='homepage-btn') }}
            {{ button(url='/programs/create', button_text='Create a Program', extra_classes='homepage-btn') }}
        </div>
    </div>
    {% endif %}

</section>

<section style="padding: 20px; text-align: center;">
    {{ button(url='/logout', button_text='Log Out', extra_classes='homepage-btn') }}
</section>

{% endblock %}