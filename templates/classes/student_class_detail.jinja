{% extends "base.jinja" %}
{% block title %}{{ cls.name }}{% endblock %}
{% block content %}
{% from 'button.jinja' import button %}

<section id="hero" style="padding: 40px 20px; text-align: center;">
    <h1>{{ cls.name }}</h1>
    {% if cls.description %}
        <p style="max-width: 700px; margin: 0.5rem auto; opacity:0.8;">{{ cls.description }}</p>
    {% endif %}
</section>

<section style="padding: 0 20px 40px 20px; max-width: 900px; margin: 0 auto;">

    <div class="container-full">
        <h2 style="margin-bottom: 1rem;">Assignments</h2>
        {% if assignments %}
            <div style="display: flex; flex-direction: column; gap: 12px;">
                {% for a in assignments %}
                    {% set sub = sub_map.get(a.assignment_id) %}
                    <a href="{{ url_for('classes.assignment_detail', class_id=cls.class_id, assignment_id=a.assignment_id) }}"
                       style="
                           display: flex;
                           align-items: center;
                           justify-content: space-between;
                           flex-wrap: wrap;
                           gap: 10px;
                           text-decoration: none;
                           color: var(--text);
                           background: var(--background);
                           border: 1.5px solid var(--primary);
                           border-radius: 12px;
                           padding: 14px 20px;
                           transition: border-color 0.2s;
                       "
                       onmouseover="this.style.borderColor='var(--green)'"
                       onmouseout="this.style.borderColor='var(--primary)'">
                        <div>
                            <span style="font-weight: 700; font-size:1.05rem;">{{ a.title }}</span>
                            {% if a.description %}
                                <p style="margin:4px 0 0; opacity:0.65; font-size:0.9rem;">{{ a.description | truncate(80) }}</p>
                            {% endif %}
                        </div>
                        <div style="display:flex; gap:8px; align-items:center; flex-wrap:wrap;">
                            <span style="
                                background: var(--green3);
                                border: 1px solid var(--primary);
                                border-radius: 8px;
                                padding: 4px 12px;
                                font-size: 0.85rem;
                            ">{{ a.max_marks }} marks</span>

                            {% if sub %}
                                {% if sub.marks is not none %}
                                    <span style="
                                        background: var(--primary_darker);
                                        border-radius: 8px;
                                        padding: 4px 12px;
                                        font-size: 0.85rem;
                                        font-weight: 700;
                                    ">{{ sub.marks }}/{{ a.max_marks }} ✓</span>
                                {% else %}
                                    <span style="
                                        background: var(--accent);
                                        border-radius: 8px;
                                        padding: 4px 12px;
                                        font-size: 0.85rem;
                                    ">Submitted — awaiting mark</span>
                                {% endif %}
                            {% else %}
                                <span style="
                                    background: var(--background);
                                    border: 1px dashed var(--accent);
                                    border-radius: 8px;
                                    padding: 4px 12px;
                                    font-size: 0.85rem;
                                    opacity: 0.8;
                                ">Not submitted</span>
                            {% endif %}
                        </div>
                    </a>
                {% endfor %}
            </div>
        {% else %}
            <p style="opacity:0.6;">Your teacher has not set any assignments yet.</p>
        {% endif %}
    </div>

</section>

<section style="padding: 0 20px 20px; max-width: 900px; margin: 0 auto;">
    {{ button(url=url_for('classes.classes_index'), button_text='← Back to Classes', extra_classes='homepage-btn') }}
</section>

{% endblock %}
