{% extends "base.jinja" %}
{% block title %}Species Database{% endblock %}
{% block head %}
{% endblock %}
{% block content %}
{% from 'button.jinja' import button %}
{% from 'featured_species.jinja' import featured_species_section%}
<section class="title">
Species Database
</section>
{# Featured Species #}
{# If you want to change the featured species please do so in config.ini - CS #}
{{featured_species_section(featured_species, False)}}
{# All Species #}
<h2 style="text-align: center; margin-top: 30px;">All Species</h2>
<section class="species-grid">
    {% for sp in species %}
    <a href="/species/{{ sp['species_english'] }}" class="container-lite">
        <h3 class="plain-white-text">{{ sp['species_english'] }}</h3>
        <div 
        style="background-image: url('{{ url_for('static', filename='images/species_database/' ~ sp['species_english'] ~ '.jpg') }}');" class="div-image">
        </div>
        <p style="color: var(--text)">
        Main category: {{ sp['category'] }}
        </p>
    </a>

    {% endfor %}
</section>
{% endblock %}