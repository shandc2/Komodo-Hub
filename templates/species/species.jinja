{% extends "base.jinja" %}
{% block title %}Species Database{% endblock %}
{% block head %}
{% endblock %}
{% block content %}
{% from 'button.jinja' import button %}
{% from 'featured_species.jinja' import featured_species_section %}
{% from 'display_items.jinja' import display_all_items %}
<section class="title">
Species Database
</section>
{# Featured Species #}
{# If you want to change the featured species please do so in config.ini - CS #}
{{featured_species_section(featured_species, False)}}
{# All Species #}
<div>
    <form action="/species/search" method="GET" class="search">
        <input type="text" name="search-query" placeholder="Search all species..." class="bar">
        <input type="submit" value="Search" class="button">
    </form>
</div>
<h2 style="text-align: center; margin-top: 30px;">All Species</h2>
{{display_all_items(species)}}
{% endblock %}