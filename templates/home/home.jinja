{% extends "base.jinja" %}
{% block title %}Home{% endblock %}
{% block head %}
{% endblock %}
{% block content %}
{% from 'button.jinja' import button %}
<!-- Banner section -->
<section id="hero" style="padding: 0px 20px 0px 20px; text-align: center;">
    <h1 class="title" data-text="Komodo Hub">Komodo Hub</h1>   
    <img src="/images/image.png" class="komodo_crop half-width" alt="I stole this photo from the internet"> 
    <h1>Protecting Indonesia's Endangered Species Together</h1>
    <p>Komodo Hub is dedicated to safeguarding the incredible biodiversity of Indonesia. Join us in our mission to
        conserve and protect these precious creatures for future generations.</p>
    <!-- Main buttons -->
    <div class="homepage-buttons">
        {{ button(url='/donation', button_text='Donate Now', extra_classes='homepage-btn') }}
        {{ button(url='#featured-species', button_text='Explore Species', extra_classes='homepage-btn') }}
        {{ button(url='/register', button_text='Join the Movement', extra_classes='homepage-btn') }}
    </div>
</section>
<!-- About section -->
<section id="about" style="padding: 50px 20px; text-align: center;">
    <h2>What is Komodo Hub?</h2>
    <p style="max-width: 800px; margin: 1rem auto;">Komodo Hub is a digital platform designed to support conservation and
        species protection efforts across Indonesia. We connect passionate individuals, educators, and organizations to
        make a tangible difference.
    </p>
    {{ button(url='/about', button_text='Read More', extra_classes='homepage-btn') }}
</section>
<!-- Featured Species -->
<section id="featured-species" style="padding: 50px 20px; background-color: #047f02; text-align: center;">
    <h2>Featured Species</h2>
    <div style="display: flex; justify-content: center; flex-wrap: wrap; gap: 20px; margin-top: 30px;">
        <div style="border: 1px solid #ddd; padding: 20px; border-radius: 8px; width: 250px;">
            <h3><a href="/animal/iguana" style="text-decoration: none; color: #333;">Fecking iguana</a></h3>
            <p>Main category: Reptile</p>
        </div>
        <div style="border: 1px solid #ddd; padding: 20px; border-radius: 8px; width: 250px;">
            <h3><a href="/species/sumatran-tiger" style="text-decoration: none; color: #333;">Sumatran Tiger</a></h3>
            <p>Main category: Mammal</p>
        </div>
        <div style="border: 1px solid #ddd; padding: 20px; border-radius: 8px; width: 250px;">
            <h3><a href="/species/orangutan" style="text-decoration: none; color: #333;">Orangutan</a></h3>
            <p>Main category: Mammal</p>
        </div>
    </div>
    <a href="/species"
        style="display: inline-block; margin-top: 40px; background-color: #555; color: white; padding: 10px 20px; text-decoration: none; border-radius: 5px;">View
        All Species</a>
</section>
<!-- Schools & communities section -->
<section id="schools-communities" style="padding: 50px 20px; text-align: center; background-color: #094d21;">
    <h2>Schools & Communities</h2>
    <p style="max-width: 800px; margin: 0 auto;">Schools and communities play a vital role in conservation. Discover how
        your group can get involved through educational programs, fundraising, and awareness campaigns.</p>
    </div>
    <div class="homepage-buttons">
        {{ button(url='/register-school', button_text='Register Your School', extra_classes='homepage-btn') }}
        <!-- need to assign bg colour -->
        {{ button(url='/register-community', button_text='Join as a Community', extra_classes='homepage-btn') }}
    </div>
</section>
{% endblock %}